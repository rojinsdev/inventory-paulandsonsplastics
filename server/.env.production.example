# Production Environment Variables
# Copy this file to .env on the AWS server

PORT=4000
NODE_ENV=production

# Supabase Credentials (Get these from your Supabase Project Settings)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Database Connection (Transaction Pooler - Recommended for Production)
DATABASE_URL="postgresql://postgres.[PROJ_ID]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Database Connection (Direct - for Migrations)
DIRECT_URL="postgresql://postgres.[PROJ_ID]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# --- Google Sheets mirror (optional; see docs/GOOGLE_SHEETS_SYNC.md) ---
# Not a substitute for Supabase backups / PITR.
# SHEETS_SYNC_ENABLED=true
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_from_url
# Prefer file path on the server:
# GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
# Or single-line JSON (private_key newlines as \n):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# SHEETS_SNAPSHOT_CRON=15 2 * * *
