# Production Environment Variables
# Copy this file to .env on the AWS server

PORT=4000
NODE_ENV=production

# Supabase Credentials (Get these from your Supabase Project Settings)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Database Connection (Transaction Pooler - Recommended for Production)
DATABASE_URL="postgresql://postgres.[PROJ_ID]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Database Connection (Direct - for Migrations)
DIRECT_URL="postgresql://postgres.[PROJ_ID]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"
