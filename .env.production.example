# Production Environment Variables Example
# Copy this to .env.production on your production server

NODE_ENV=production
PORT=4000
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_KEY=your-production-service-role-key

# Comma-separated list of allowed origins (e.g., your production website)
ALLOWED_ORIGINS=https://paulandsonsplastics.com,https://api.paulandsonsplastics.com

# Optional: Telegram Notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Firebase (for Notifications)
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
